{
    "manifest_version": 3,
    "name": "PhishGuard - Intent-Aware Phishing Detection",
    "version": "1.0.0",
    "description": "Detects phishing URLs using intent analysis, brand impersonation detection, typosquatting, and real-time risk scoring. Blocks high-risk sites and warns users of suspicious URLs.",
    "author": "Security Team",
    "icons": {
        "16": "icons/Icon.jpg",
        "48": "icons/Icon.jpg",
        "128": "icons/Icon.jpg"
    },
    "permissions": [
        "activeTab",
        "storage",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "PhishGuard - Phishing Detection",
        "default_icon": {
            "16": "icons/Icon.jpg",
            "48": "icons/Icon.jpg",
            "128": "icons/Icon.jpg"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "styles.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}